---
// CYBER BRAIN 2026 - Landing Page
---

<html lang="pl">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="CYBER BRAIN 2026 - Uniwersytet w Białymstoku, 9-12 marca. Biologiczne i sztuczne sieci neuronowe." />
    <title>CYBER BRAIN 2026 | UwB</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;700&family=Poppins:wght@300;400;600;700&family=Roboto+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/global.css" />
  </head>
  <body>
    <canvas id="network"></canvas>

    <div class="brain-container">
      <img src="/brain-lateral.png" alt="" class="brain-image" />
    </div>
    
    <main>
      <section class="hero">
        <h1>CYBER BRAIN</h1>
        <p class="subtitle hero-subtitle">Dowiedz się jak myśli Twój mózg</p>
        <p class="location">IX Tydzień Mózgu w Białymstoku</p>
        <p class="dates">9–12 marca 2026</p>
        
        <div class="cta">
          <a href="/program" class="button button-secondary">Program</a>
          <a href="/prelegenci" class="button button-secondary">Prelegenci</a>
        </div>
      </section>

      <section class="about">
        <h2>O wydarzeniu</h2>
        <p class="about-text">
          CYBER BRAIN to białostocka odsłona międzynarodowego <strong>Brain Awareness Week</strong> – 
          ogólnoświatowej inicjatywy popularyzującej wiedzę o mózgu i układzie nerwowym. 
          Przez cztery dni naukowcy, praktycy i entuzjaści spotykają się, by rozmawiać o tym, 
          jak działa nasz mózg – i jak działają jego sztuczne odpowiedniki.
        </p>
        <p class="about-text">
          Wykłady, warsztaty i dyskusje prowadzone przez badaczy z Uniwersytetu w Białymstoku 
          i zaproszonych gości. Tematyka: od neurobiologii przez kognitywistykę po sztuczną inteligencję.
        </p>
      </section>

      <section class="faq">
        <h2>FAQ</h2>
        <div class="faq-grid">
          <div class="faq-item">
            <h3>Czy wstęp jest płatny?</h3>
            <p>Nie. Wszystkie wydarzenia CYBER BRAIN są <strong>bezpłatne</strong> i otwarte dla każdego.</p>
          </div>
          <div class="faq-item">
            <h3>Czy muszę się rejestrować?</h3>
            <p>Nie ma obowiązkowej rejestracji. Przyjdź i weź udział.</p>
          </div>
          <div class="faq-item">
            <h3>Gdzie odbywają się wydarzenia?</h3>
            <p class="venue-line">Wydział Filozofii i Kognitywistyki UwB (sala 108A), Plac NZS 1</p>
            <p class="venue-line">Wydział Informatyki PB (Aula B5), ul. Wiejska 45A</p>
            <p class="venue-line">Wydział Fizyki UwB, ul. Ciołkowskiego 1L</p>
            <p class="venue-line">Kawiarnia Fama, ul. Legionowa 5</p>
            <p>Szczegóły lokalizacji w <a href="/program">programie</a>.</p>
          </div>
          <div class="faq-item">
            <h3>Dla kogo jest to wydarzenie?</h3>
            <p>Dla wszystkich zainteresowanych – studentów, uczniów, profesjonalistów i hobbystów. Nie wymagamy specjalistycznej wiedzy.</p>
          </div>
        </div>
      </section>

      <section class="share">
        <div class="share-row">
          <div class="share-card">
            <img src="/qr.png" alt="QR kod - cyberbrain.pl" class="share-qr" />
            <div class="share-text">
              <p class="share-label">Podziel się</p>
              <p class="share-url">cyberbrain.pl</p>
            </div>
          </div>
          <div class="share-card contact-card">
            <div class="contact-text">
              <p class="share-label">Kontakt</p>
              <a href="mailto:kognistok@gmail.com" class="contact-link">kognistok@gmail.com</a>
              <div class="social-links">
                <a href="https://www.facebook.com/knk.uwb" target="_blank" rel="noopener" class="social-link" aria-label="Facebook">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                </a>
                <a href="https://www.instagram.com/knk_uwb" target="_blank" rel="noopener" class="social-link" aria-label="Instagram">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
                </a>
              </div>
            </div>
          </div>
          <a href="https://facebook.com/events/s/cyber-brain-ix-tydzien-mozgu-2/1419799899599984/" target="_blank" rel="noopener" class="share-card event-card">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="event-icon"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            <div class="event-text">
              <p class="share-label">Wydarzenie</p>
              <p class="event-cta">Dołącz na Facebooku</p>
            </div>
          </a>
        </div>
      </section>

      <footer class="patrons">
        <div class="footer-row">
          <p class="patrons-label">Organizacja</p>
          <div class="patrons-logos">
            <a href="https://uwb.edu.pl" target="_blank" rel="noopener">
              <img src="/logo-uwb.png" alt="Uniwersytet w Białymstoku" class="patron-logo logo-uwb" />
            </a>
            <img src="/logo-knk.png" alt="Koło Naukowe Kognitywistów UwB" class="patron-logo logo-round" />
            <a href="https://filozofia.uwb.edu.pl" target="_blank" rel="noopener">
              <img src="/logo-wfik.png" alt="Wydział Filozofii i Kognitywistyki UwB" class="patron-logo" />
            </a>
            <a href="https://pb.edu.pl" target="_blank" rel="noopener">
              <img src="/logo-pb.png" alt="Politechnika Białostocka" class="patron-logo logo-pb" />
            </a>
          </div>
        </div>
        <div class="footer-row">
          <p class="patrons-label">Patronat</p>
          <div class="patrons-logos">
            <a href="https://ptbun.org.pl" target="_blank" rel="noopener">
              <img src="/logo-ptbun.png" alt="Polskie Towarzystwo Badań Układu Nerwowego" class="patron-logo" />
            </a>
          </div>
        </div>
      </footer>
    </main>

    <style>
      body { overflow-x: hidden; }

      #network {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 1;
      }

      .brain-container {
        position: fixed;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: min(75vw, 550px);
        z-index: 2;
        pointer-events: none;
      }

      .brain-image {
        width: 100%;
        height: auto;
        mix-blend-mode: screen;
        opacity: 0.3;
        filter: saturate(0.9) brightness(1.1);
        transform: scaleX(-1);
        mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 30%, transparent 70%);
        -webkit-mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 30%, transparent 70%);
      }

      main {
        position: relative;
        z-index: 3;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 2rem;
      }

      .hero {
        min-height: 85vh;
        min-height: 85svh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
      }

      .hero h1 {
        font-size: clamp(2.5rem, 8vw, 5rem);
        opacity: 0;
        animation: fadeUp 1.5s ease-out 0.8s forwards;
      }

      .hero.animated h1,
      .hero.animated .hero-subtitle,
      .hero.animated .location,
      .hero.animated .dates,
      .hero.animated .cta {
        animation: none;
        opacity: 1;
        transform: none;
      }

      .hero-subtitle {
        font-size: 0.95rem;
        color: var(--text-light);
        letter-spacing: 0.15em;
        margin-top: 0.5rem;
        margin-bottom: 0.5rem;
        opacity: 0;
        animation: fadeUp 1.5s ease-out 1s forwards;
      }

      .location {
        font-size: 1.05rem;
        font-weight: 600;
        color: var(--text-light);
        letter-spacing: 0.1em;
        margin-top: 0.3rem;
        margin-bottom: 0.8rem;
        opacity: 0;
        animation: fadeUp 1.5s ease-out 1.2s forwards;
      }

      .dates {
        font-family: var(--font-mono);
        font-size: 1.2rem;
        font-weight: 500;
        color: var(--accent-cyan);
        letter-spacing: 0.2em;
        margin-bottom: 2.5rem;
        opacity: 0;
        animation: fadeUp 1.5s ease-out 1.4s forwards;
      }

      .cta {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
        opacity: 0;
        animation: fadeUp 1.5s ease-out 1.6s forwards;
      }

      .cta .button-secondary {
        background: rgba(0, 0, 0, 0.5);
      }

      @keyframes fadeUp {
        0% { opacity: 0; transform: translateY(20px); }
        100% { opacity: 1; transform: translateY(0); }
      }

      .about, .faq {
        max-width: 800px;
        width: 100%;
        padding: 4rem 2rem;
        text-align: center;
        background: rgba(0, 0, 0, 0.3);
        border-radius: 12px;
        margin-bottom: 2rem;
      }

      .about h2, .faq h2 {
        font-family: var(--font-title);
        font-size: 1.5rem;
        font-weight: 400;
        color: var(--accent-cyan);
        letter-spacing: 0.1em;
        text-transform: uppercase;
        margin-bottom: 2rem;
      }

      .about-text {
        font-size: 1rem;
        font-weight: 300;
        line-height: 1.8;
        color: var(--text-mid);
        margin-bottom: 1.5rem;
      }

      .about-text:last-child { margin-bottom: 0; }

      .about-text strong { color: var(--text-light); font-weight: 600; }

      .faq-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2rem;
        text-align: center;
      }

      .faq-item h3 {
        font-size: 1rem;
        font-weight: 600;
        color: var(--accent-pink);
        margin-bottom: 0.5rem;
      }

      .faq-item p {
        font-size: 0.9rem;
        font-weight: 300;
        line-height: 1.6;
        color: var(--text-mid);
      }

      .faq-item p strong { color: var(--text-light); font-weight: 600; }
      .faq-item a { color: var(--accent-cyan); text-decoration: none; }
      .faq-item a:hover { text-decoration: underline; }

      .venue-line {
        margin-bottom: 0.2rem;
        font-size: 0.9rem;
        color: var(--text-mid);
        padding-left: 1rem;
        position: relative;
      }

      .venue-line::before {
        content: '▸';
        position: absolute;
        left: 0;
        color: var(--accent-cyan);
      }

      .share {
        padding: 3rem 2rem 4rem;
      }

      .share-row {
        display: flex;
        gap: 1.5rem;
        max-width: 700px;
        margin: 0 auto;
        justify-content: center;
        align-items: stretch;
      }

      .share-card {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        flex: 1;
        max-width: 340px;
        background: rgba(0, 0, 0, 0.45);
        border: 1px solid rgba(110, 39, 225, 0.2);
        border-radius: 8px;
        padding: 1.5rem 1.5rem;
        transition: border-color 0.3s ease;
      }

      .share-card:hover {
        border-color: rgba(110, 39, 225, 0.4);
      }

      .contact-card {
        flex-direction: column;
        align-items: flex-start;
        gap: 0.5rem;
      }

      .share-qr {
        width: 140px;
        height: 140px;
        flex-shrink: 0;
      }

      .share-text {
        text-align: left;
      }

      .share-label {
        font-size: 0.75rem;
        font-weight: 300;
        color: var(--text-dim);
        letter-spacing: 0.1em;
        text-transform: uppercase;
        margin-bottom: 0.4rem;
      }

      .share-url {
        font-family: var(--font-mono);
        font-size: 1.1rem;
        font-weight: 500;
        color: var(--accent-cyan);
      }

      .contact-text {
        text-align: left;
      }

      .contact-link {
        font-family: var(--font-mono);
        font-size: 0.8rem;
        font-weight: 400;
        color: var(--accent-cyan);
        text-decoration: none;
        word-break: break-all;
        transition: color 0.2s ease;
      }

      .contact-link:hover {
        color: var(--accent-pink);
      }

      .social-links {
        display: flex;
        gap: 0.75rem;
        margin-top: 0.75rem;
      }

      .social-link {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        border-radius: 50%;
        border: 1px solid rgba(110, 39, 225, 0.25);
        color: var(--text-dim);
        transition: all 0.3s ease;
      }

      .social-link:hover {
        color: var(--accent-cyan);
        border-color: var(--accent-cyan);
        background: rgba(64, 208, 213, 0.08);
      }

      .event-card {
        display: flex;
        align-items: center;
        gap: 1rem;
        text-decoration: none;
        cursor: pointer;
      }

      .event-icon {
        color: var(--text-dim);
        flex-shrink: 0;
        transition: color 0.3s ease;
      }

      .event-card:hover .event-icon {
        color: var(--accent-cyan);
      }

      .event-text {
        text-align: left;
      }

      .event-cta {
        font-family: var(--font-mono);
        font-size: 0.85rem;
        color: var(--text-mid);
        transition: color 0.3s ease;
      }

      .event-card:hover .event-cta {
        color: var(--accent-cyan);
      }

      .patrons {
        padding: 2rem 2rem 3rem;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 3rem;
        flex-wrap: wrap;
      }

      .footer-row { text-align: center; }

      .patrons-label {
        font-size: 0.75rem;
        font-weight: 300;
        color: var(--text-dim);
        letter-spacing: 0.15em;
        text-transform: uppercase;
        margin-bottom: 1rem;
      }

      .patrons-logos {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 3rem;
        flex-wrap: wrap;
      }

      .patrons-logos a {
        display: block;
        opacity: 0.45;
        transition: opacity 0.3s ease;
      }

      .patrons-logos a:hover {
        opacity: 0.8;
      }

      .patron-logo {
        height: 45px;
        width: auto;
      }

      .patron-logo.logo-round {
        height: 65px;
        border-radius: 50%;
        opacity: 0.45;
        transition: opacity 0.3s ease;
      }

      .patron-logo.logo-round:hover {
        opacity: 0.8;
      }

      .patron-logo.logo-uwb {
        height: 62px;
      }

      .patron-logo.logo-pb {
        height: 41px;
      }

      @media (max-width: 600px) {
        main { padding: 1rem; }
        .about, .faq { padding: 3rem 1rem; }
        .faq-grid { grid-template-columns: 1fr; }
        .share-row { flex-direction: column; align-items: center; }
        .share-card { max-width: 100%; }
      }
    </style>

    <script>
      const canvas = document.getElementById('network');
      const ctx = canvas.getContext('2d');

      const colors = [
        { r: 110, g: 39, b: 225 },
        { r: 64, g: 208, b: 213 },
        { r: 242, g: 135, b: 200 }
      ];

      function pickColor() {
        const r = Math.random();
        if (r < 0.55) return colors[0];
        if (r < 0.80) return colors[1];
        return colors[2];
      }

      function drawNetwork() {
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
        ctx.clearRect(0, 0, canvas.width, canvas.height);

        const nodeCount = Math.floor((canvas.width * canvas.height) / 10000);
        const nodes = [];
        for (let i = 0; i < nodeCount; i++) {
          nodes.push({
            x: Math.random() * canvas.width,
            y: Math.random() * canvas.height,
            color: pickColor(),
            radius: Math.random() * 1.5 + 1,
            opacity: Math.random() * 0.3 + 0.4,
            maxConnDist: 80 + Math.random() * 120
          });
        }

        for (let i = 0; i < nodes.length; i++) {
          for (let j = i + 1; j < nodes.length; j++) {
            const a = nodes[i], b = nodes[j];
            const dist = Math.hypot(a.x - b.x, a.y - b.y);
            const maxDist = Math.min(a.maxConnDist, b.maxConnDist);
            if (dist < maxDist) {
              const strength = 1 - dist / maxDist;
              const opacity = (0.08 + strength * 0.4) * Math.min(a.opacity, b.opacity);
              if (opacity > 0.04) {
                ctx.beginPath();
                ctx.moveTo(a.x, a.y);
                ctx.lineTo(b.x, b.y);
                ctx.strokeStyle = `rgba(${(a.color.r + b.color.r) / 2}, ${(a.color.g + b.color.g) / 2}, ${(a.color.b + b.color.b) / 2}, ${opacity})`;
                ctx.lineWidth = 0.5 + strength * 1.2;
                ctx.stroke();
              }
            }
          }
        }

        for (const n of nodes) {
          const c = n.color;
          ctx.beginPath();
          ctx.arc(n.x, n.y, n.radius * 3, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(${c.r}, ${c.g}, ${c.b}, ${n.opacity * 0.12})`;
          ctx.fill();
          ctx.beginPath();
          ctx.arc(n.x, n.y, n.radius, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(${c.r}, ${c.g}, ${c.b}, ${n.opacity})`;
          ctx.fill();
        }
      }

      // Initial draw
      drawNetwork();

      // Lock animations after they finish so they never replay
      setTimeout(() => {
        document.querySelector('.hero').classList.add('animated');
      }, 3500);

      // Redraw canvas on width change only (no page reload)
      let lastWidth = window.innerWidth;
      window.addEventListener('resize', () => {
        if (window.innerWidth !== lastWidth) {
          lastWidth = window.innerWidth;
          drawNetwork();
        }
      });
    </script>
  </body>
</html>